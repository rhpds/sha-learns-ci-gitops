{{- $lab := include "labHelloWorld" . | fromYaml -}}
{{ if and .Values.labs.helloWorld.enabled $lab.app.enabled -}}
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: hello-world-{{ .Values.tenant.name | lower }}
  namespace: openshift-gitops
  labels:
    app: hello-world
    tenant: {{ .Values.tenant.name | lower }}
  finalizers:
    - resources-finalizer.argocd.argoproj.io
spec:
  project: default
  source:
    repoURL: {{ $lab.app.git.url }}
    targetRevision: {{ $lab.app.git.revision }}
    path: {{ $lab.app.git.path }}
    helm:
      values: |
        # Pass tenant context
        tenant:
          name: {{ .Values.tenant.name }}

        # Pass deployer context
        deployer:
          domain: {{ .Values.deployer.domain }}
          apiUrl: {{ .Values.deployer.apiUrl }}

        # Pass hello-world specific values
        message: {{ $lab.app.message | quote }}
        replicas: {{ $lab.app.replicas }}
        imageTag: {{ $lab.app.imageTag | quote }}

  destination:
    server: https://kubernetes.default.svc
    namespace: {{ .Values.tenant.namespace.lab }}

  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=false  # Namespace already created by tenant_namespace workload
      - SkipDryRunOnMissingResource=true
      - RespectIgnoreDifferences=true
    retry:
      limit: 10
      backoff:
        duration: 5s
        factor: 2
        maxDuration: 3m
{{- end }}
